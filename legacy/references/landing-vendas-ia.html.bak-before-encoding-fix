  <script>
    (function () {
      "use strict";

      var FRAME_COUNT = 240;
      var ROTATION_INTERVAL_MS = 42;
      var DRAG_SENSITIVITY_PX = 3;
      var BASE_PATHS = [
        "../images/Frame/",
        "./images/Frame/",
        "file:///C:/Users/KR%20PIX/Downloads/sites/Opera/images/Frame/"
      ];

      var spinRoot = document.getElementById("hero-spin");
      var spinImage = document.getElementById("hero-spin-frame");

      if (!spinRoot || !spinImage) {
        return;
      }

      var currentFrame = 0;
      var autoDirection = 1;
      var autoplayTimer = null;
      var isDragging = false;
      var lastPointerX = 0;
      var activeBasePath = BASE_PATHS[0];
      var preloaded = new Array(FRAME_COUNT);

      function frameName(index) {
        return "frame" + String(index).padStart(3, "0") + ".jpg";
      }

      function framePath(index) {
        return activeBasePath + frameName(index);
      }

      function wrapFrame(index) {
        return (index + FRAME_COUNT) % FRAME_COUNT;
      }

      function renderFrame(index) {
        currentFrame = wrapFrame(index);
        var cached = preloaded[currentFrame];
        spinImage.src = cached ? cached.src : framePath(currentFrame);
      }

      function stopAutoplay() {
        if (autoplayTimer !== null) {
          clearInterval(autoplayTimer);
          autoplayTimer = null;
        }
      }

      function startAutoplay() {
        stopAutoplay();
        autoplayTimer = setInterval(function () {
          if (isDragging) return;
          renderFrame(currentFrame + autoDirection);
        }, ROTATION_INTERVAL_MS);
      }

      function preloadFrames() {
        for (var i = 0; i < FRAME_COUNT; i += 1) {
          var image = new Image();
          image.src = framePath(i);
          preloaded[i] = image;
        }
      }

      function canLoad(src) {
        return new Promise(function (resolve) {
          var probe = new Image();
          probe.onload = function () { resolve(true); };
          probe.onerror = function () { resolve(false); };
          probe.src = src;
        });
      }

      async function resolveBasePath() {
        for (var i = 0; i < BASE_PATHS.length; i += 1) {
          var candidate = BASE_PATHS[i];
          var ok = await canLoad(candidate + "frame000.jpg");
          if (ok) {
            return candidate;
          }
        }
        return null;
      }

      function onPointerDown(event) {
        if (event.button !== undefined && event.button !== 0) return;
        isDragging = true;
        spinRoot.classList.add("dragging");
        lastPointerX = event.clientX;
        stopAutoplay();
        if (spinRoot.setPointerCapture) {
          spinRoot.setPointerCapture(event.pointerId);
        }
      }

      function onPointerMove(event) {
        if (!isDragging) return;
        var deltaX = event.clientX - lastPointerX;
        if (Math.abs(deltaX) < DRAG_SENSITIVITY_PX) return;

        var steps = Math.floor(Math.abs(deltaX) / DRAG_SENSITIVITY_PX);
        var direction = deltaX > 0 ? -1 : 1;
        autoDirection = direction;
        renderFrame(currentFrame + (direction * steps));
        lastPointerX = event.clientX;
      }

      function endDrag(event) {
        if (!isDragging) return;
        isDragging = false;
        spinRoot.classList.remove("dragging");

        if (
          event &&
          typeof event.pointerId === "number" &&
          spinRoot.releasePointerCapture &&
          spinRoot.hasPointerCapture(event.pointerId)
        ) {
          spinRoot.releasePointerCapture(event.pointerId);
        }

        startAutoplay();
      }

      async function init() {
        var resolved = await resolveBasePath();
        if (!resolved) {
          return;
        }

        activeBasePath = resolved;
        spinImage.src = framePath(0);
        preloadFrames();
        renderFrame(0);
        startAutoplay();
      }

      spinRoot.addEventListener("pointerdown", onPointerDown);
      spinRoot.addEventListener("pointermove", onPointerMove);
      spinRoot.addEventListener("pointerup", endDrag);
      spinRoot.addEventListener("pointercancel", endDrag);
      spinRoot.addEventListener("lostpointercapture", function () { endDrag(); });
      window.addEventListener("mouseup", endDrag);

      init();
    })();
  </script>
